NODE_ENV=development
PORT=5000

# Database — PostgreSQL via Docker (docker compose up -d)
DB_CLIENT=pg
DATABASE_URL=postgresql://postgres:postgres@localhost:5435/pharos_db

# RabbitMQ
RABBITMQ_URL=amqp://pharos:pharos123@localhost:5672

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=pharos_jwt_secret_key_extremely_long_and_safe
JWT_ACCESS_SECRET=pharos_jwt_secret_key_extremely_long_and_safe
JWT_REFRESH_SECRET=pharos_jwt_refresh_secret_key_extremely_long_and_safe

# File Storage
REPORTS_DIR=./generated-reports

# CORS Frontend
FRONTEND_URL=http://localhost:5173